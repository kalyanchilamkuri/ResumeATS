{
  "manifest_version": 3,
  "name": "ResumeATS-X",
  "version": "1.0.0",
  "description": "Live ATS match scoring for resumes in Overleaf — no downloads, no separate websites.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://*.overleaf.com/*", "http://localhost:5000/*"],
  "content_scripts": [
    {
      "matches": ["https://*.overleaf.com/project/*"],
      "js": ["content/content.js"]
    },
    {
      "matches": ["https://*.overleaf.com/project/*"],
      "js": ["content/page-bridge.js"],
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
