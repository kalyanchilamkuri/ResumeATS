:root {
  color-scheme: light;
  --bg: #eef3ff;
  --bg-2: #f8fbff;
  --surface: rgba(255, 255, 255, 0.78);
  --surface-strong: rgba(255, 255, 255, 0.96);
  --surface-soft: rgba(255, 255, 255, 0.62);
  --border: rgba(15, 23, 42, 0.10);
  --border-strong: rgba(15, 23, 42, 0.16);
  --text: #0f172a;
  --text-muted: #52607a;
  --text-soft: #7c869e;
  --primary: #2563eb;
  --primary-strong: #1d4ed8;
  --accent: #14b8a6;
  --accent-strong: #0f766e;
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  --neutral: #64748b;
  --shadow-lg: 0 24px 60px rgba(15, 23, 42, 0.12);
  --shadow-md: 0 16px 34px rgba(15, 23, 42, 0.10);
  --shadow-sm: 0 8px 18px rgba(15, 23, 42, 0.08);
  --radius-xl: 24px;
  --radius-lg: 18px;
  --radius-md: 14px;
  --radius-sm: 10px;
  --radius-full: 999px;
  --transition: 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

html[data-theme='dark'] {
  color-scheme: dark;
  --bg: #060814;
  --bg-2: #0b1020;
  --surface: rgba(12, 17, 33, 0.78);
  --surface-strong: rgba(16, 22, 39, 0.94);
  --surface-soft: rgba(255, 255, 255, 0.05);
  --border: rgba(148, 163, 184, 0.14);
  --border-strong: rgba(148, 163, 184, 0.22);
  --text: #f8fafc;
  --text-muted: #b6c2d6;
  --text-soft: #7f8ca8;
  --primary: #60a5fa;
  --primary-strong: #3b82f6;
  --accent: #2dd4bf;
  --accent-strong: #14b8a6;
  --success: #34d399;
  --warning: #fbbf24;
  --danger: #f87171;
  --neutral: #94a3b8;
  --shadow-lg: 0 24px 60px rgba(0, 0, 0, 0.42);
  --shadow-md: 0 16px 34px rgba(0, 0, 0, 0.32);
  --shadow-sm: 0 8px 18px rgba(0, 0, 0, 0.24);
}

* {
  box-sizing: border-box;
}

html {
  width: 460px;
    width: 396px;
  min-height: 100%;
}

body {
  width: 460px;
    width: 396px;
  min-height: 100vh;
  margin: 0;
  overflow: hidden;
  color: var(--text);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
  background:
    padding: 12px;
    radial-gradient(circle at top right, rgba(20, 184, 166, 0.16), transparent 24%),
    linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
}

button,
input,
textarea {
  font: inherit;
    justify-content: space-between;
    padding: 12px 14px;
button {
  cursor: pointer;
}

::selection {
  background: rgba(37, 99, 235, 0.24);
}
    gap: 12px;
    padding-top: 12px;
    max-height: calc(100vh - 84px);
  min-height: 100vh;
  padding: 14px;
  overflow: hidden;
}

    grid-template-columns: 1fr;
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(40px);
  opacity: 0.8;
    padding: 14px;

.ambient-a {
  width: 170px;
  height: 170px;
    font-size: 20px;
  left: -48px;
  background: rgba(37, 99, 235, 0.18);
}

.ambient-b {
    font-size: 17px;
  height: 220px;
  top: 180px;
  right: -90px;
  background: rgba(20, 184, 166, 0.14);
    margin-top: 12px;
    padding: 12px;
.ambient-c {
  width: 180px;
  height: 180px;
    margin-top: 12px;
  left: 110px;
  background: rgba(245, 158, 11, 0.10);
    gap: 9px;

.glass-panel {
  background: var(--surface);
  border: 1px solid var(--border);
    min-height: 148px;
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

    grid-template-columns: 1fr;
    gap: 8px;
    margin-top: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
    padding: 11px;
  padding: 14px 16px;
}

.brand {
  display: flex;
  align-items: center;
    padding: 14px;
  min-width: 0;
}

.brand-mark {
  display: grid;
  place-items: center;
  width: 42px;
    grid-template-columns: 1fr;
    gap: 8px;
  color: var(--primary);
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.38)),
    grid-template-columns: 1fr;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}
    grid-template-columns: 1fr;
html[data-theme='dark'] .brand-mark {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
    linear-gradient(135deg, rgba(59, 130, 246, 0.18), rgba(45, 212, 191, 0.16));
}
    grid-template-columns: repeat(2, minmax(0, 1fr));
.brand-copy {
  min-width: 0;
}

.eyebrow {
  margin: 0 0 4px;
    grid-template-columns: 1fr;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-soft);
}

    justify-content: stretch;
.panel-title,
    flex-direction: column;
.panel-subtitle,
.section-heading,
.saved-target-title,
    width: 100%;
.error-title,
.feature-card h3,
.preview-card strong {
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  letter-spacing: -0.04em;
}

.brand-title {
  margin: 0;
  font-size: 18px;
  line-height: 1.1;
}

.brand-subtitle {
  margin: 4px 0 0;
  font-size: 12px;
  color: var(--text-muted);
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.live-pill,
.pill,
.mini-badge,
.meta-chip,
.theme-status,
.mono-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: var(--radius-full);
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.34);
  color: var(--text);
  font-size: 12px;
  font-weight: 700;
  line-height: 1;
  padding: 8px 12px;
}

.pill-status.status-success {
  color: #0f5132;
  background: rgba(16, 185, 129, 0.12);
  border-color: rgba(16, 185, 129, 0.22);
}

.pill-status.status-warning {
  color: #7a4a00;
  background: rgba(245, 158, 11, 0.14);
  border-color: rgba(245, 158, 11, 0.24);
}

.pill-status.status-danger {
  color: #7f1d1d;
  background: rgba(239, 68, 68, 0.12);
  border-color: rgba(239, 68, 68, 0.24);
}

.pill-status.status-neutral {
  color: var(--text);
  background: rgba(100, 116, 139, 0.12);
  border-color: rgba(100, 116, 139, 0.18);
}

html[data-theme='dark'] .pill-status.status-success {
  color: #d1fae5;
}

html[data-theme='dark'] .pill-status.status-warning {
  color: #fde68a;
}

html[data-theme='dark'] .pill-status.status-danger {
  color: #fecaca;
}

html[data-theme='dark'] .live-pill,
html[data-theme='dark'] .pill,
html[data-theme='dark'] .mini-badge,
html[data-theme='dark'] .meta-chip,
html[data-theme='dark'] .theme-status,
html[data-theme='dark'] .mono-chip {
  background: rgba(255, 255, 255, 0.04);
}

.live-pill {
  color: var(--text-muted);
}

.pulse-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.45);
  animation: pulse 1.8s ease-out infinite;
}

.icon-button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  color: var(--text);
  background: rgba(255, 255, 255, 0.34);
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background var(--transition);
}

html[data-theme='dark'] .icon-button {
  background: rgba(255, 255, 255, 0.04);
}

.icon-button:hover {
  transform: translateY(-1px);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding-top: 14px;
  max-height: calc(100vh - 88px);
  overflow-y: auto;
  overflow-x: hidden;
}

.content::-webkit-scrollbar {
  width: 8px;
}

.content::-webkit-scrollbar-thumb {
  border-radius: var(--radius-full);
  background: rgba(148, 163, 184, 0.34);
}

.view {
  display: none;
}

.view.active {
  display: block;
  animation: fadeUp 280ms ease both;
}

.hero-grid,
.results-grid,
.loading-layout {
  display: grid;
  gap: 14px;
}

.hero-grid {
  grid-template-columns: 1.4fr 0.9fr;
}

.results-grid {
  grid-template-columns: 1fr;
}

.loading-layout {
  grid-template-columns: 1fr;
}

.panel,
.card-section,
.error-panel {
  padding: 16px;
}

.hero-panel,
.preview-panel,
.form-card,
.loading-hero,
.error-panel {
  position: relative;
  overflow: hidden;
}

.hero-panel::before,
.preview-panel::before,
.form-card::before,
.loading-hero::before,
.error-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(37, 99, 235, 0.07), transparent 26%);
  pointer-events: none;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
}

.panel-header-compact {
  align-items: center;
}

.panel-title {
  margin: 0;
  font-size: 22px;
  line-height: 1.05;
}

.panel-subtitle {
  margin: 0;
  font-size: 18px;
  line-height: 1.15;
}

.panel-copy {
  margin: 10px 0 0;
  color: var(--text-muted);
  font-size: 13px;
  line-height: 1.6;
}

.status-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
  text-align: right;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  border-radius: var(--radius-full);
  padding: 9px 12px;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.01em;
  border: 1px solid transparent;
}

.status-badge.success {
  color: #0f5132;
  background: rgba(16, 185, 129, 0.12);
  border-color: rgba(16, 185, 129, 0.22);
}

.status-badge.warning {
  color: #7a4a00;
  background: rgba(245, 158, 11, 0.14);
  border-color: rgba(245, 158, 11, 0.24);
}

.status-badge.danger {
  color: #7f1d1d;
  background: rgba(239, 68, 68, 0.12);
  border-color: rgba(239, 68, 68, 0.24);
}

.status-badge.neutral {
  color: var(--text);
  background: rgba(100, 116, 139, 0.12);
  border-color: rgba(100, 116, 139, 0.18);
}

html[data-theme='dark'] .status-badge.success {
  color: #d1fae5;
}

html[data-theme='dark'] .status-badge.warning {
  color: #fde68a;
}

html[data-theme='dark'] .status-badge.danger {
  color: #fecaca;
}

.status-metric {
  color: var(--text-soft);
  font-size: 12px;
  font-weight: 600;
}

.saved-target-card,
.preview-card,
.feature-card,
.stat-card,
.content-card,
.results-actions,
.loading-card,
.error-panel {
  border: 1px solid var(--border);
  background: var(--surface-soft);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.saved-target-card {
  margin-top: 14px;
  padding: 14px;
  background:
    linear-gradient(160deg, rgba(37, 99, 235, 0.12), rgba(20, 184, 166, 0.10)),
    var(--surface-soft);
}

.saved-target-top,
.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.saved-target-title {
  margin: 12px 0 8px;
  font-size: 18px;
}

.saved-target-summary {
  margin: 0;
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.65;
}

.mono-chip {
  font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
  font-size: 11px;
  letter-spacing: 0.02em;
}

.jd-form {
  margin-top: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.helper-text {
  margin: 0;
  color: var(--text-soft);
  font-size: 12px;
  line-height: 1.5;
}

.form-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-soft);
}

.form-input,
.form-textarea {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.76);
  color: var(--text);
  padding: 12px 13px;
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition), background var(--transition);
}

html[data-theme='dark'] .form-input,
html[data-theme='dark'] .form-textarea {
  background: rgba(8, 12, 24, 0.72);
}

.form-textarea {
  resize: vertical;
  min-height: 176px;
  line-height: 1.6;
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: var(--text-soft);
}

.form-input:focus,
.form-textarea:focus {
  border-color: rgba(37, 99, 235, 0.48);
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.14);
  transform: translateY(-1px);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 0;
  border-radius: var(--radius-md);
  font-weight: 800;
  letter-spacing: 0.01em;
  transition: transform var(--transition), box-shadow var(--transition), opacity var(--transition), background var(--transition);
}

.btn:hover {
  transform: translateY(-1px);
}

.btn:active {
  transform: translateY(0);
}

.btn-primary {
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--accent));
}

.btn-primary:hover {
  box-shadow: 0 18px 28px rgba(37, 99, 235, 0.22);
}

.btn-secondary,
.btn-ghost {
  color: var(--text);
  background: rgba(255, 255, 255, 0.48);
  border: 1px solid var(--border);
}

html[data-theme='dark'] .btn-secondary,
html[data-theme='dark'] .btn-ghost {
  background: rgba(255, 255, 255, 0.04);
}

.btn-ghost {
  box-shadow: none;
}

.btn-secondary:hover,
.btn-ghost:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.btn-elevated {
  box-shadow: var(--shadow-sm);
}

.btn-glow {
  position: relative;
  overflow: hidden;
}

.btn-glow::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.22) 50%, transparent 100%);
  transform: translateX(-110%);
  transition: transform 600ms ease;
}

.btn-glow:hover::after {
  transform: translateX(110%);
}

.btn-sm {
  padding: 9px 12px;
  font-size: 12px;
}

.btn:not(.btn-sm) {
  min-height: 44px;
  padding: 11px 16px;
}

.btn-icon {
  flex-shrink: 0;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 14px;
}

.feature-card {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.feature-icon {
  width: fit-content;
  min-width: 32px;
  padding: 7px 9px;
  border-radius: var(--radius-full);
  background: rgba(37, 99, 235, 0.12);
  color: var(--primary);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.08em;
}

.feature-card h3 {
  margin: 0;
  font-size: 14px;
}

.feature-card p {
  margin: 0;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.6;
}

.preview-panel {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.preview-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 6px;
}

.preview-card {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.preview-card-accent {
  background: linear-gradient(160deg, rgba(37, 99, 235, 0.14), rgba(20, 184, 166, 0.10));
}

.preview-label {
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.preview-card strong {
  font-size: 15px;
  line-height: 1.28;
}

.preview-card p {
  margin: 0;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.6;
}

.guidance-card {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.guidance-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.guidance-item {
  padding: 12px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.34);
  border: 1px solid var(--border);
}

html[data-theme='dark'] .guidance-item {
  background: rgba(255, 255, 255, 0.04);
}

.guidance-item strong {
  display: block;
  margin-bottom: 6px;
  font-size: 13px;
}

.guidance-item p {
  margin: 0;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.6;
}

.loading-layout {
  gap: 14px;
}

.loading-copy {
  margin: 0;
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
  font-weight: 600;
}

.loading-grid,
.skeleton-grid {
  display: grid;
  gap: 12px;
}

.loading-card,
.skeleton-panel {
  padding: 16px;
}

.loading-card.wide {
  grid-column: 1 / -1;
}

.skeleton,
.skeleton-card,
.skeleton-line,
.skeleton-row,
.skeleton-item,
.skeleton-pill,
.skeleton-circle,
.skeleton-ring {
  position: relative;
  overflow: hidden;
  background: rgba(148, 163, 184, 0.14);
}

.skeleton::after,
.skeleton-card::after,
.skeleton-line::after,
.skeleton-row::after,
.skeleton-item::after,
.skeleton-pill::after,
.skeleton-circle::after,
.skeleton-ring::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.24) 50%, transparent 100%);
  transform: translateX(-120%);
  animation: shimmer 1.8s ease-in-out infinite;
}

.hero-skeleton-line {
  height: 14px;
  border-radius: var(--radius-full);
  margin-bottom: 10px;
}

.hero-skeleton-line.long {
  width: 92%;
  height: 28px;
}

.hero-skeleton-line.medium {
  width: 78%;
}

.hero-skeleton-line.short {
  width: 52%;
}

.skeleton-ring-row {
  display: grid;
  grid-template-columns: 128px 1fr;
  gap: 14px;
  align-items: center;
  margin: 14px 0;
}

.skeleton-circle,
.skeleton-ring {
  border-radius: 50%;
}

.skeleton-circle {
  width: 126px;
  height: 126px;
}

.skeleton-copy-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.skeleton-stat-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.skeleton-card {
  height: 90px;
  border-radius: var(--radius-md);
}

.skeleton-score-list,
.skeleton-list,
.skeleton-pills {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.skeleton-row {
  height: 64px;
  border-radius: var(--radius-md);
}

.skeleton-item {
  height: 72px;
  border-radius: var(--radius-md);
}

.skeleton-pill-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.skeleton-pill {
  width: 74px;
  height: 28px;
  border-radius: var(--radius-full);
}

.results-hero {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.results-copy {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.results-title {
  margin: 0;
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  font-size: 24px;
  letter-spacing: -0.04em;
}

.results-summary {
  margin: 0;
  color: var(--text-muted);
  font-size: 13px;
  line-height: 1.6;
}

.meta-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 6px;
}

.meta-chip {
  color: var(--text-muted);
}

.results-score-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  flex-wrap: wrap;
}

.score-ring-shell {
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.score-ring {
  --ring-progress: 0deg;
  --ring-color: var(--primary);
  position: relative;
  width: 148px;
  height: 148px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: conic-gradient(var(--ring-color) var(--ring-progress), rgba(148, 163, 184, 0.18) 0deg);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08), var(--shadow-md);
}

.score-ring::before {
  content: '';
  position: absolute;
  inset: 13px;
  border-radius: 50%;
  background: var(--surface-strong);
  border: 1px solid var(--border);
}

.score-value,
.score-label {
  position: relative;
  z-index: 1;
}

.score-value {
  display: block;
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  font-size: 42px;
  line-height: 1;
  font-weight: 700;
  letter-spacing: -0.06em;
}

.score-label {
  margin-top: 4px;
  font-size: 12px;
  font-weight: 700;
  color: var(--text-soft);
}

.score-caption {
  margin: 0;
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.hero-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.score-narrative {
  font-size: 14px;
  line-height: 1.65;
  color: var(--text-muted);
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.meta-item {
  padding: 12px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.36);
  border: 1px solid var(--border);
}

html[data-theme='dark'] .meta-item {
  background: rgba(255, 255, 255, 0.04);
}

.meta-item span {
  display: block;
  margin-bottom: 8px;
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.meta-item strong {
  font-size: 18px;
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  letter-spacing: -0.04em;
}

.insight-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.stat-card {
  padding: 14px;
}

.stat-label {
  display: block;
  margin-bottom: 8px;
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.stat-value {
  display: block;
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.04em;
}

.stat-card p {
  margin: 8px 0 0;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.5;
}

.insight-card {
  padding: 14px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.36);
  transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
}

html[data-theme='dark'] .insight-card {
  background: rgba(255, 255, 255, 0.04);
}

.insight-card:hover {
  transform: translateY(-1px);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.insight-label {
  display: block;
  margin-bottom: 8px;
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.insight-value {
  display: flex;
  align-items: baseline;
  gap: 6px;
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.05em;
}

.insight-copy {
  margin: 8px 0 0;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.55;
}

.insight-track {
  margin-top: 12px;
  height: 8px;
  border-radius: var(--radius-full);
  background: rgba(148, 163, 184, 0.16);
  overflow: hidden;
}

.insight-fill {
  height: 100%;
  width: 0;
  border-radius: inherit;
  transition: width 700ms cubic-bezier(0.22, 1, 0.36, 1);
  background: linear-gradient(90deg, var(--primary), var(--accent));
}

.metric-grid {
  display: grid;
  gap: 12px;
}

.sub-score-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}

.sub-score-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.sub-score-header,
.sub-score-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.sub-score-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
}

.sub-score-weight {
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 700;
}

.sub-score-track {
  flex: 1;
  min-width: 0;
  height: 8px;
  border-radius: var(--radius-full);
  background: rgba(148, 163, 184, 0.18);
  overflow: hidden;
}

.sub-score-fill {
  height: 100%;
  width: 0;
  border-radius: inherit;
  transition: width 800ms cubic-bezier(0.22, 1, 0.36, 1);
}

.sub-score-number {
  min-width: 34px;
  text-align: right;
  font-size: 13px;
  font-weight: 800;
}

.fill-red {
  background: linear-gradient(90deg, #ef4444, #f97316);
}

.fill-orange {
  background: linear-gradient(90deg, #f59e0b, #f97316);
}

.fill-green {
  background: linear-gradient(90deg, #10b981, #14b8a6);
}

.card-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.section-heading {
  margin: 0;
  font-size: 18px;
  line-height: 1.1;
}

.section-support {
  margin: 0;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.5;
}

.content-grid,
.panel-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.issues-list,
.keywords-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.issue-card {
  display: flex;
  gap: 12px;
  padding: 13px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.38);
  transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
}

html[data-theme='dark'] .issue-card {
  background: rgba(255, 255, 255, 0.04);
}

.issue-card:hover {
  transform: translateY(-1px);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.issue-main {
  min-width: 0;
  flex: 1;
}

.issue-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 8px;
}

.severity-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  border-radius: var(--radius-full);
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.severity-badge.high {
  background: rgba(239, 68, 68, 0.12);
  color: var(--danger);
}

.severity-badge.medium {
  background: rgba(245, 158, 11, 0.14);
  color: var(--warning);
}

.severity-badge.low {
  background: rgba(16, 185, 129, 0.12);
  color: var(--success);
}

.issue-type {
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.issue-message {
  color: var(--text);
  font-size: 13px;
  font-weight: 600;
  line-height: 1.55;
}

.issue-context,
.issue-suggestion {
  margin-top: 6px;
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.6;
}

.issue-suggestion {
  color: var(--primary);
}

.keyword-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  border-radius: var(--radius-full);
  padding: 8px 11px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.44);
  color: var(--text);
  font-size: 12px;
  font-weight: 700;
  transition: transform var(--transition), border-color var(--transition), background var(--transition);
}

html[data-theme='dark'] .keyword-pill {
  background: rgba(255, 255, 255, 0.04);
}

.keyword-pill:hover {
  transform: translateY(-1px);
  border-color: rgba(37, 99, 235, 0.36);
  background: rgba(37, 99, 235, 0.10);
}

.keyword-weight {
  color: var(--text-soft);
  font-size: 11px;
  font-weight: 800;
}

.results-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
}

.footer-copy {
  margin: 0;
  color: var(--text-soft);
  font-size: 12px;
  line-height: 1.5;
  text-align: center;
}

.error-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 30px 20px;
  text-align: center;
}

.error-icon {
  display: grid;
  place-items: center;
  width: 68px;
  height: 68px;
  border-radius: 22px;
  color: var(--danger);
  background: rgba(239, 68, 68, 0.10);
  border: 1px solid rgba(239, 68, 68, 0.18);
}

.error-title {
  margin: 0;
  font-size: 22px;
}

.error-message {
  margin: 0;
  max-width: 320px;
  color: var(--text-muted);
  font-size: 14px;
  line-height: 1.7;
}

.error-actions {
  display: flex;
  justify-content: center;
}

.score-color-red {
  color: var(--danger);
}

.score-color-orange {
  color: var(--warning);
}

.score-color-green {
  color: var(--success);
}

@keyframes shimmer {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(120%); }
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.45);
  }
  70% {
    box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
  }
}

@media (max-width: 420px) {
  html,
  body {
    width: 100%;
  }

  .app-shell {
    padding: 12px;
  }

  .topbar {
    flex-wrap: wrap;
  }

  .hero-grid,
  .content-grid,
  .panel-grid,
  .feature-grid,
  .guidance-grid,
  .insight-grid,
  .meta-grid,
  .skeleton-stat-grid,
  .skeleton-ring-row {
    grid-template-columns: 1fr;
  }

  .results-actions {
    justify-content: stretch;
    flex-direction: column;
  }

  .results-actions .btn {
    width: 100%;
  }

  .panel-header,
  .results-score-panel {
    flex-direction: column;
    align-items: flex-start;
  }

  .status-stack {
    align-items: flex-start;
    text-align: left;
  }

  .score-ring {
    width: 136px;
    height: 136px;
  }

  .score-ring::before {
    inset: 12px;
  }
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}