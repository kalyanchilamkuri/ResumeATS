<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ResumeATS-X</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="popup.css" />
</head>
<body>
  <div class="app-shell">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient ambient-c"></div>

    <header class="topbar glass-panel">
      <div class="brand">
        <div class="brand-mark" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M4 5.5A1.5 1.5 0 0 1 5.5 4h8.3a1.5 1.5 0 0 1 1.06.44l4.7 4.7a1.5 1.5 0 0 1 .44 1.06v8.3A1.5 1.5 0 0 1 18.5 20h-13A1.5 1.5 0 0 1 4 18.5v-13Z" stroke="currentColor" stroke-width="1.8"/>
            <path d="M8 8.2h6M8 12h7M8 15.8h4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="17.4" cy="17.4" r="3.1" fill="currentColor" opacity="0.18"/>
            <path d="m16.2 17.3 0.9 0.9 1.9-2.1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="eyebrow">Resume intelligence</p>
          <h1 class="brand-title">ResumeATS-X</h1>
        </div>
      </div>

      <div class="topbar-actions">
        <span id="theme-status" class="theme-status" aria-live="polite">System</span>
        <button id="theme-toggle" class="icon-button" type="button" aria-label="Toggle theme">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M21 12.8A8.5 8.5 0 1111.2 3 7 7 0 0021 12.8Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </header>

    <main class="content">
      <section id="empty-state" class="view">
        <div class="hero-grid">
          <article class="glass-panel form-card">
            <div class="card-heading">
              <div>
                <p class="card-kicker">Target role</p>
                <h3>Enter the job title and job description</h3>
              </div>
              <p class="card-support">Fill these fields, then run the score check.</p>
            </div>

            <div id="saved-target-card" class="saved-target-card">
              <div class="saved-target-top">
                <span id="saved-target-badge" class="mini-badge">Saved target</span>
                <span id="saved-target-project" class="mono-chip">Project loading…</span>
              </div>
              <h3 id="saved-target-title" class="saved-target-title">No saved role yet</h3>
              <p id="saved-target-summary" class="saved-target-summary">
                Paste a job description to create a benchmark and score the resume against it.
              </p>
            </div>

            <form id="jd-form" class="jd-form" autocomplete="off">
              <label for="job-title" class="form-label">Job Title</label>
              <input
                type="text"
                id="job-title"
                class="form-input"
                placeholder="e.g. Senior Frontend Engineer"
                required
              />

              <label for="job-description" class="form-label">Job Description</label>
              <textarea
                id="job-description"
                class="form-textarea"
                rows="9"
                placeholder="Paste the full job description here…"
                required
              ></textarea>

              <div class="form-actions">
                <button type="submit" id="btn-save-score" class="btn btn-primary btn-elevated btn-glow">
                  <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Save &amp; Score
                </button>
                <p class="helper-text">This checks the current Overleaf resume against the saved role.</p>
              </div>
            </form>
          </article>

          <article class="glass-panel intro-card">
            <span class="pill pill-accent">No upload required</span>
            <h2>Score the active Overleaf resume against the role you pasted above.</h2>
            <p class="lead-copy">
              The app does not upload files. It reads the current Overleaf project, saves the target role, and then runs the ATS score.
            </p>

            <div class="feature-grid">
              <div class="feature-item">
                <span class="feature-kicker">01</span>
                <p>Open your resume in Overleaf first.</p>
              </div>
              <div class="feature-item">
                <span class="feature-kicker">02</span>
                <p>Enter the job title and full job description.</p>
              </div>
              <div class="feature-item">
                <span class="feature-kicker">03</span>
                <p>Click Save &amp; Score to see the dashboard.</p>
              </div>
            </div>
          </article>
        </div>

        <article class="glass-panel guidance-card">
          <div>
            <p class="card-kicker">What happens next</p>
            <h3>From saved role to score dashboard</h3>
          </div>
          <div class="guidance-grid">
            <div class="guidance-item">
              <strong>Save</strong>
              <p>The job title and description are stored locally and sent to the backend.</p>
            </div>
            <div class="guidance-item">
              <strong>Extract</strong>
              <p>The extension reads the active Overleaf project through the content script.</p>
            </div>
            <div class="guidance-item">
              <strong>Score</strong>
              <p>The backend returns composite score, sub-scores, issues, and missing keywords.</p>
            </div>
          </div>
        </article>
      </section>

      <section id="loading-state" class="view">
        <div class="results-grid skeleton-grid">
          <article class="panel hero-panel glass-panel skeleton-panel">
            <div class="skeleton hero-skeleton-line long"></div>
            <div class="skeleton hero-skeleton-line medium"></div>
            <div class="skeleton-ring-row">
              <div class="skeleton skeleton-circle"></div>
              <div class="skeleton-copy-stack">
                <div class="skeleton hero-skeleton-line short"></div>
                <div class="skeleton hero-skeleton-line medium"></div>
                <div class="skeleton hero-skeleton-line short"></div>
              </div>
            </div>
            <div class="skeleton-stat-grid">
              <div class="skeleton skeleton-card"></div>
              <div class="skeleton skeleton-card"></div>
              <div class="skeleton skeleton-card"></div>
              <div class="skeleton skeleton-card"></div>
            </div>
          </article>

          <article class="panel glass-panel skeleton-panel">
            <div class="skeleton hero-skeleton-line medium"></div>
            <div class="skeleton-score-list">
              <div class="skeleton skeleton-row"></div>
              <div class="skeleton skeleton-row"></div>
              <div class="skeleton skeleton-row"></div>
              <div class="skeleton skeleton-row"></div>
            </div>
          </article>

          <div class="panel-grid">
            <article class="panel glass-panel skeleton-panel">
              <div class="skeleton hero-skeleton-line short"></div>
              <div class="skeleton-list">
                <div class="skeleton skeleton-item"></div>
                <div class="skeleton skeleton-item"></div>
                <div class="skeleton skeleton-item"></div>
              </div>
            </article>
            <article class="panel glass-panel skeleton-panel">
              <div class="skeleton hero-skeleton-line short"></div>
              <div class="skeleton-pills">
                <div class="skeleton skeleton-pill"></div>
                <div class="skeleton skeleton-pill"></div>
                <div class="skeleton skeleton-pill"></div>
                <div class="skeleton skeleton-pill"></div>
                <div class="skeleton skeleton-pill"></div>
                <div class="skeleton skeleton-pill"></div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="results-state" class="view">
        <div class="results-grid">
          <article class="panel hero-panel glass-panel">
            <div class="panel-header">
              <div>
                <p class="eyebrow">Scoring result</p>
                <span id="score-badge" class="pill pill-status status-neutral">Live analysis</span>
                <h2 class="panel-title">ATS Match Dashboard</h2>
                <p id="score-summary" class="panel-copy">
                  A high-level view of how the resume aligns with the selected role.
                </p>
              </div>
              <div class="toolbar-actions">
                <button id="btn-rescore" class="btn btn-secondary" type="button" title="Re-score resume">
                  <svg class="btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M1 4v6h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M3.51 15a9 9 0 105.64-11.36L1 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Rescore
                </button>
                <button id="btn-edit-jd" class="btn btn-ghost" type="button">Edit JD</button>
              </div>
            </div>

            <div class="hero-score-row">
              <div class="score-ring-shell">
                <div id="score-ring" class="score-ring">
                  <span id="score-value" class="score-value">0</span>
                  <span class="score-label">/ 100</span>
                </div>
              </div>

              <div class="hero-copy">
                <span id="score-status" class="status-badge">Analyzing</span>
                <div id="score-narrative" class="score-narrative">
                  Hold tight while the dashboard converts raw scoring into actionable guidance.
                </div>

                <div class="meta-grid">
                  <div class="meta-item">
                    <span>Keyword gaps</span>
                    <strong id="keyword-gap-count">0</strong>
                  </div>
                  <div class="meta-item">
                    <span>Critical issues</span>
                    <strong id="issue-count">0</strong>
                  </div>
                  <div class="meta-item">
                    <span>Section coverage</span>
                    <strong id="section-coverage-value">0%</strong>
                  </div>
                </div>

                <div class="meta-chips">
                  <span id="target-pill" class="meta-chip">Role</span>
                  <span id="project-pill" class="meta-chip">Project</span>
                  <span id="updated-pill" class="meta-chip">Live</span>
                </div>
              </div>
            </div>

            <div id="insight-grid" class="insight-grid" aria-live="polite"></div>
          </article>

          <article class="panel glass-panel">
            <div class="panel-header panel-header-compact">
              <div>
                <p class="eyebrow">Score breakdown</p>
                <h3 class="panel-subtitle">Four signals shaping the ATS result.</h3>
              </div>
              <span id="overall-score-chip" class="mini-badge">Live analysis</span>
            </div>
            <div id="sub-scores" class="sub-scores"></div>
          </article>

          <section class="overview-grid">
            <article class="stat-card">
              <span class="stat-label">Composite</span>
              <strong id="overview-score" class="stat-value">--</strong>
              <p>Overall readiness</p>
            </article>
            <article class="stat-card">
              <span class="stat-label">Issues</span>
              <strong id="overview-issues" class="stat-value">--</strong>
              <p>High-impact blockers</p>
            </article>
            <article class="stat-card">
              <span class="stat-label">Keywords</span>
              <strong id="overview-keywords" class="stat-value">--</strong>
              <p>Missing terms</p>
            </article>
            <article class="stat-card">
              <span class="stat-label">Focus</span>
              <strong id="overview-focus" class="stat-value">--</strong>
              <p>Highest leverage fix</p>
            </article>
          </section>

          <div class="panel-grid">
            <article id="issues-section" class="panel glass-panel card-section">
              <div class="section-header">
                <div>
                  <p class="eyebrow">Top issues</p>
                  <h3 class="section-heading">Fix the highest-impact blockers first.</h3>
                </div>
                <span class="mini-badge">Ranked</span>
              </div>
              <div id="issues-list" class="issues-list"></div>
            </article>

            <article id="keywords-section" class="panel glass-panel card-section">
              <div class="section-header">
                <div>
                  <p class="eyebrow">Missing keywords</p>
                  <h3 class="section-heading">Uncovered terms from the job description.</h3>
                </div>
                <span class="mini-badge">Adaptive</span>
              </div>
              <div id="keywords-list" class="keywords-list"></div>
            </article>
          </div>

          <footer class="results-footer">
            <p class="footer-copy">Tip: edit the job description and rescore to compare iterations instantly.</p>
          </footer>
        </div>
      </section>

      <section id="error-state" class="view">
        <div class="error-panel glass-panel">
          <div class="error-icon" aria-hidden="true">
            <svg width="54" height="54" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/>
              <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="error-title">We hit a snag</p>
          <p id="error-message" class="error-message">Something went wrong.</p>
          <div class="error-actions">
            <button id="btn-try-again" class="btn btn-primary btn-glow" type="button">Try Again</button>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script src="popup.js"></script>
</body>
</html>