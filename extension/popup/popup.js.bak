/**
 * ResumeATS-X — Popup Logic
 *
 * Manages the popup view states, handles theme preferences,
 * restores cached job context and score results, and renders the
 * redesigned dashboard experience.
 */
(() => {
  'use strict';

  const STORAGE_KEYS = {
    theme: 'resumeatsx.theme',
    jobPrefix: 'resumeatsx.job.',
    scorePrefix: 'resumeatsx.score.'
  };

  const SUB_SCORE_META = [
    { key: 'keywordMatch', label: 'Keyword Match', weight: '40%' },
    { key: 'quantification', label: 'Quantification', weight: '25%' },
    { key: 'sectionCoverage', label: 'Section Coverage', weight: '20%' },
    { key: 'parseability', label: 'Parseability', weight: '15%' },
  ];

  const ISSUE_TYPE_LABELS = {
    weak_verb: 'Weak verb usage',
    missing_metric: 'Missing metrics',
    ats_risk: 'ATS risk',
    missing_section: 'Missing section',
    'Keyword/Focus Mismatch': 'Keyword / focus mismatch',
    'Formatting/Structure': 'Formatting / structure',
    Quantification: 'Quantification gap',
    'Content Gap': 'Content gap',
    'Parseability/Formatting': 'Parseability / formatting'
  };

  const $ = (selector) => document.querySelector(selector);

  const views = {
    empty: $('#empty-state'),
    loading: $('#loading-state'),
    results: $('#results-state'),
    error: $('#error-state'),
  };

  const els = {
    jdForm: $('#jd-form'),
    jobTitle: $('#job-title'),
    jobDescription: $('#job-description'),
    btnSaveScore: $('#btn-save-score'),
    btnRescore: $('#btn-rescore'),
    btnEditJd: $('#btn-edit-jd'),
    btnTryAgain: $('#btn-try-again'),
    themeToggle: $('#theme-toggle'),
    themeToggleIcon: $('#theme-toggle-icon'),
    themeToggleLabel: $('#theme-toggle-label'),
    themeStatus: $('#theme-status'),
    savedTargetCard: $('#saved-target-card'),
    savedTargetBadge: $('#saved-target-badge'),
    savedTargetProject: $('#saved-target-project'),
    savedTargetTitle: $('#saved-target-title'),
    savedTargetSummary: $('#saved-target-summary'),
    emptyStatus: $('#empty-status'),
    scoreBadge: $('#score-badge'),
    scoreSummary: $('#score-summary'),
    scoreRing: $('#score-ring'),
    scoreValue: $('#score-value'),
    scoreStatus: $('#score-status'),
    scoreNarrative: $('#score-narrative'),
    keywordGapCount: $('#keyword-gap-count'),
    issueCount: $('#issue-count'),
    sectionCoverageValue: $('#section-coverage-value'),
    overviewScore: $('#overview-score'),
    overviewIssues: $('#overview-issues'),
    overviewKeywords: $('#overview-keywords'),
    overviewFocus: $('#overview-focus'),
    targetPill: $('#target-pill'),
    projectPill: $('#project-pill'),
    updatedPill: $('#updated-pill'),
    overallScoreChip: $('#overall-score-chip'),
    subScores: $('#sub-scores'),
    insightGrid: $('#insight-grid'),
    issuesList: $('#issues-list'),
    issuesSection: $('#issues-section'),
    keywordsList: $('#keywords-list'),
    keywordsSection: $('#keywords-section'),
    errorMessage: $('#error-message'),
    loadingCopy: $('#loading-copy'),
  };

  let currentTabId = null;
  let currentProjectId = null;
  let currentJobTitle = '';
  let currentJobDesc = '';
  let currentTheme = 'dark';
  let lastAction = null;
  let lastScore = null;

  const storageGet = (keys) => new Promise((resolve) => chrome.storage.local.get(keys, resolve));
  const storageSet = (items) => new Promise((resolve) => chrome.storage.local.set(items, resolve));

  const showView = (viewId) => {
    Object.values(views).forEach((view) => view?.classList.remove('active'));
    views[viewId]?.classList.add('active');
  };

  const showError = (message) => {
    els.errorMessage.textContent = message;
    showView('error');
  };

  const setSetupMode = (enabled, message) => {
    els.jobTitle.disabled = !enabled;
    els.jobDescription.disabled = !enabled;
    els.btnSaveScore.disabled = !enabled;
    els.btnSaveScore.textContent = enabled ? 'Save & Score' : 'Open Overleaf First';
    if (els.savedTargetTitle) {
      els.savedTargetTitle.textContent = enabled ? 'No saved role yet' : 'Open an Overleaf project first';
    }

    if (els.savedTargetSummary) {
      els.savedTargetSummary.textContent = message || (enabled
        ? 'Paste a job description to create a benchmark and score the resume against it.'
        : 'This extension reads the active Overleaf resume. Open a project first, then paste the job title and job description here.');
    }

    if (els.savedTargetBadge) {
      els.savedTargetBadge.textContent = enabled ? 'Saved target' : 'Setup required';
    }

    if (els.emptyStatus) {
      els.emptyStatus.textContent = enabled ? 'Ready to configure' : 'Open Overleaf first';
    }
  };

  const sendMessage = (payload) => new Promise((resolve, reject) => {
    chrome.runtime.sendMessage(payload, (response) => {
      if (chrome.runtime.lastError) {
        reject(new Error(chrome.runtime.lastError.message));
        return;
      }
      resolve(response);
    });
  });

  const getThemePreference = async () => {
    const result = await storageGet([STORAGE_KEYS.theme]);
    return result[STORAGE_KEYS.theme] || null;
  };

  const saveThemePreference = async (theme) => {
    await storageSet({ [STORAGE_KEYS.theme]: theme });
  };

  const applyTheme = (theme) => {
    const resolved = theme === 'light' || theme === 'dark'
      ? theme
      : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

    document.documentElement.dataset.theme = resolved;
    currentTheme = resolved;

    const isDark = resolved === 'dark';
    if (els.themeStatus) {
      els.themeStatus.textContent = isDark ? 'Dark' : 'Light';
    }

    if (els.themeToggleLabel) {
      els.themeToggleLabel.textContent = isDark ? 'Light' : 'Dark';
    }

    if (els.themeToggleIcon) {
      els.themeToggleIcon.textContent = isDark ? '☀' : '☾';
    }

    if (els.themeToggle) {
      els.themeToggle.setAttribute('aria-label', `Switch to ${isDark ? 'light' : 'dark'} theme`);
    }
  };

  const getScoreTone = (score) => {
    if (score < 40) return 'red';
    if (score < 70) return 'orange';
    return 'green';
  };

  const getScoreLabel = (score) => {
    if (score >= 85) return 'Strong fit';
    if (score >= 70) return 'Promising';
    if (score >= 50) return 'Needs tuning';
    return 'At risk';
  };

  const getNarrative = (score, focusArea) => {
    if (score >= 85) {
      return `This resume is aligned well with the target role. Fine-tune ${focusArea} to push the score even higher.`;
    }
    if (score >= 70) {
      return `The core profile is solid. The fastest gains are likely in ${focusArea} and keyword alignment.`;
    }
    if (score >= 50) {
      return `There is a workable foundation, but ${focusArea} is holding the score back.`;
    }
    return `The resume needs targeted edits before it will read cleanly through ATS filters. Start with ${focusArea}.`;
  };

  const truncate = (text, maxLength = 120) => {
    const value = String(text || '').trim();
    if (value.length <= maxLength) return value;
    return `${value.slice(0, maxLength - 1).trim()}…`;
  };

  const formatProjectPill = (projectId) => {
    if (!projectId) return 'Project not loaded';
    return `Project ${projectId.slice(0, 6)}`;
  };

  const formatTimestamp = (isoString) => {
    if (!isoString) return 'Live';
    const date = new Date(isoString);
    if (Number.isNaN(date.getTime())) return 'Live';
    return `Last scored ${date.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })}`;
  };

  const formatIssueType = (type) => {
    if (!type) return 'Issue';
    return ISSUE_TYPE_LABELS[type] || String(type).replace(/_/g, ' ');
  };

  const formatJobSummary = (jobTitle, jobDescription) => {
    if (!jobDescription) {
      return 'Paste a job description to create a benchmark and score the current resume against it.';
    }

    const title = jobTitle ? `${jobTitle} · ` : '';
    return `${title}${truncate(jobDescription, 140)}`;
  };

  const updateSavedTargetCard = ({ jobTitle = '', jobDescription = '', hasSaved = false }) => {
    if (els.savedTargetBadge) {
      els.savedTargetBadge.textContent = hasSaved ? 'Saved target' : 'No benchmark yet';
    }

    if (els.savedTargetProject) {
      els.savedTargetProject.textContent = currentProjectId ? formatProjectPill(currentProjectId) : 'Project loading…';
    }

    els.savedTargetTitle.textContent = hasSaved && jobTitle ? jobTitle : 'No saved role yet';
    els.savedTargetSummary.textContent = formatJobSummary(jobTitle, jobDescription);
    els.emptyStatus.textContent = hasSaved ? 'Saved target loaded' : 'Ready to configure';
  };

  const getCachedKeys = () => {
    if (!currentProjectId) return [];
    return [
      `${STORAGE_KEYS.jobPrefix}${currentProjectId}`,
      `${STORAGE_KEYS.scorePrefix}${currentProjectId}`,
    ];
  };

  const loadCachedProjectState = async () => {
    if (!currentProjectId) return null;

    const [jobKey, scoreKey] = getCachedKeys();
    const cached = await storageGet([jobKey, scoreKey]);
    const cachedJob = cached[jobKey] || null;
    const cachedScore = cached[scoreKey] || null;

    if (cachedScore) {
      return {
        jobTitle: cachedScore.jobTitle || cachedJob?.jobTitle || '',
        jobDescription: cachedScore.jobDescription || cachedJob?.jobDescription || '',
        score: cachedScore,
        fromCache: true,
      };
    }

    if (cachedJob) {
      return {
        jobTitle: cachedJob.jobTitle || '',
        jobDescription: cachedJob.jobDescription || '',
        score: null,
        fromCache: true,
      };
    }

    try {
      const response = await sendMessage({
        action: 'GET_JOB_DESC',
        projectId: currentProjectId,
      });

      if (response?.ok && response.data) {
        const jobTitle = response.data.jobTitle || '';
        const jobDescription = response.data.jobDescription || '';

        await storageSet({
          [jobKey]: { jobTitle, jobDescription }
        });

        return { jobTitle, jobDescription, score: null, fromCache: false };
      }
    } catch (error) {
      // Fallback to the blank form when the backend has no saved JD.
    }

    return null;
  };

  const updateScoreRing = (score) => {
    const pct = Math.max(0, Math.min(100, score));
    const tone = getScoreTone(pct);
    const cssColor = tone === 'red'
      ? 'var(--danger)'
      : tone === 'orange'
        ? 'var(--warning)'
        : 'var(--success)';

    els.scoreRing.style.setProperty('--ring-progress', `${pct * 3.6}deg`);
    els.scoreRing.style.setProperty('--ring-color', cssColor);
    els.scoreValue.textContent = String(pct);
    els.scoreValue.className = `score-value score-color-${tone}`;
  };

  const animateScore = (target) => {
    const duration = 900;
    const start = performance.now();

    const tick = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(target * eased);

      updateScoreRing(current);

      if (progress < 1) {
        requestAnimationFrame(tick);
      }
    };

    requestAnimationFrame(tick);
  };

  const renderSubScores = (scores) => {
    els.subScores.innerHTML = '';

    SUB_SCORE_META.forEach(({ key, label, weight }) => {
      const value = Math.max(0, Math.min(100, Number(scores?.[key] ?? 0)));
      const tone = getScoreTone(value);
      const row = document.createElement('div');
      row.className = 'sub-score-row';

      row.innerHTML = `
        <div class="sub-score-header">
          <span class="sub-score-name">${label}</span>
          <span class="sub-score-weight">${weight}</span>
        </div>
        <div class="sub-score-meta">
          <div class="sub-score-track">
            <div class="sub-score-fill fill-${tone}" style="width: 0%"></div>
          </div>
          <span class="sub-score-number score-color-${tone}">${value}</span>
        </div>
      `;

      els.subScores.appendChild(row);

      requestAnimationFrame(() => {
        const fill = row.querySelector('.sub-score-fill');
        if (fill) fill.style.width = `${value}%`;
      });
    });
  };

  const buildInsightCards = (data) => {
    const scores = data.subScores || {};
    const composite = Math.max(0, Math.min(100, Number(data.compositeScore ?? data.score ?? 0)));
    const keywordMatch = Number(scores.keywordMatch ?? 0);
    const quantification = Number(scores.quantification ?? 0);
    const sectionCoverage = Number(scores.sectionCoverage ?? 0);
    const parseability = Number(scores.parseability ?? 0);

    const cards = [
      {
        label: 'Overall fit',
        value: `${composite}%`,
        copy: getNarrative(composite, getLowestScoreFocus(scores)),
        progress: composite,
      },
      {
        label: 'Keyword coverage',
        value: `${keywordMatch}%`,
        copy: `${data.missingKeywords?.length || 0} keywords still missing from the resume.`,
        progress: keywordMatch,
      },
      {
        label: 'Quantification',
        value: `${quantification}%`,
        copy: quantification >= 70 ? 'Strong use of metrics and action language.' : 'Improve measurable outcomes and impact language.',
        progress: quantification,
      },
      {
        label: 'Parseability',
        value: `${parseability}%`,
        copy: parseability >= 70 ? 'Readability is healthy for ATS parsing.' : 'Formatting and structure still need work.',
        progress: parseability,
      },
    ];

    els.insightGrid.innerHTML = '';
    cards.forEach((card) => {
      const node = document.createElement('article');
      node.className = 'insight-card';
      node.innerHTML = `
        <span class="insight-label">${card.label}</span>
        <div class="insight-value">${card.value}</div>
        <p class="insight-copy">${escapeHtml(card.copy)}</p>
        <div class="insight-track"><div class="insight-fill" style="width: 0%"></div></div>
      `;
      els.insightGrid.appendChild(node);

      requestAnimationFrame(() => {
        const fill = node.querySelector('.insight-fill');
        if (fill) fill.style.width = `${card.progress}%`;
      });
    });
  };

  const getLowestScoreFocus = (scores = {}) => {
    const mapped = SUB_SCORE_META.map(({ key, label }) => ({
      label,
      value: Number(scores[key] ?? 0),
    }));

    mapped.sort((a, b) => a.value - b.value);
    return mapped[0]?.label || 'keywords';
  };

  const renderIssues = (issues) => {
    els.issuesList.innerHTML = '';

    if (!issues || issues.length === 0) {
      els.issuesSection.style.display = 'none';
      return;
    }

    els.issuesSection.style.display = 'flex';

    issues.slice(0, 5).forEach((issue) => {
      const severity = ['high', 'medium', 'low'].includes(issue.severity) ? issue.severity : 'medium';
      const node = document.createElement('article');
      node.className = 'issue-card';

      const main = document.createElement('div');
      main.className = 'issue-main';

      const topline = document.createElement('div');
      topline.className = 'issue-topline';

      const severityBadge = document.createElement('span');
      severityBadge.className = `severity-badge ${severity}`;
      severityBadge.textContent = severity;

      const type = document.createElement('span');
      type.className = 'issue-type';
      type.textContent = formatIssueType(issue.type);

      topline.appendChild(severityBadge);
      topline.appendChild(type);

      const message = document.createElement('div');
      message.className = 'issue-message';
      message.textContent = issue.message || 'Review this area for improvement.';

      main.appendChild(topline);
      main.appendChild(message);

      if (issue.context) {
        const context = document.createElement('div');
        context.className = 'issue-context';
        context.textContent = issue.context;
        main.appendChild(context);
      }

      if (issue.suggestion) {
        const suggestion = document.createElement('div');
        suggestion.className = 'issue-suggestion';
        suggestion.textContent = issue.suggestion;
        main.appendChild(suggestion);
      }

      node.appendChild(main);
      els.issuesList.appendChild(node);
    });
  };

  const renderMissingKeywords = (keywords) => {
    els.keywordsList.innerHTML = '';

    if (!keywords || keywords.length === 0) {
      els.keywordsSection.style.display = 'none';
      return;
    }

    els.keywordsSection.style.display = 'flex';

    keywords.forEach((item) => {
      const term = typeof item === 'string' ? item : (item.term || '');
      const weight = typeof item === 'string' ? null : item.weight;

      const pill = document.createElement('span');
      pill.className = 'keyword-pill';
      pill.textContent = term;

      if (typeof weight === 'number') {
        const badge = document.createElement('span');
        badge.className = 'keyword-weight';
        badge.textContent = `+${weight.toFixed(1)}`;
        pill.appendChild(badge);
      }

      els.keywordsList.appendChild(pill);
    });
  };

  const renderResults = (data, options = {}) => {
    const score = Math.max(0, Math.min(100, Number(data.compositeScore ?? data.score ?? 0)));
    const tone = getScoreTone(score);
    const label = getScoreLabel(score);
    const focus = getLowestScoreFocus(data.subScores || {});
    const keywordCount = data.missingKeywords?.length || 0;
    const issueCount = data.issues?.length || 0;
    const sectionCoverage = Math.max(0, Math.min(100, Number(data.subScores?.sectionCoverage ?? 0)));

    showView('results');

    els.scoreBadge.className = `pill pill-status status-${tone === 'red' ? 'danger' : tone === 'orange' ? 'warning' : 'success'}`;
    els.scoreBadge.textContent = options.fromCache ? 'Restored from cache' : 'Live analysis';
    els.scoreSummary.textContent = getNarrative(score, focus);
    els.scoreStatus.className = `status-badge ${tone === 'red' ? 'danger' : tone === 'orange' ? 'warning' : 'success'}`;
    els.scoreStatus.textContent = label;
    els.scoreNarrative.textContent = getNarrative(score, focus);
    els.keywordGapCount.textContent = String(keywordCount);
    els.issueCount.textContent = String(issueCount);
    els.sectionCoverageValue.textContent = `${sectionCoverage}%`;
    els.overviewScore.textContent = `${score}%`;
    els.overviewIssues.textContent = String(issueCount);
    els.overviewKeywords.textContent = String(keywordCount);
    els.overviewFocus.textContent = focus;
    els.targetPill.textContent = currentJobTitle ? `Role: ${truncate(currentJobTitle, 28)}` : 'Role: Target loaded';
    els.projectPill.textContent = currentProjectId ? formatProjectPill(currentProjectId) : 'Project';
    els.updatedPill.textContent = formatTimestamp(data.updatedAt || new Date().toISOString());
    els.overallScoreChip.textContent = options.fromCache ? 'Cached result' : 'Live analysis';

    updateScoreRing(0);
    animateScore(score);
    buildInsightCards(data);
    renderSubScores(data.subScores || {});
    renderIssues(data.issues || []);
    renderMissingKeywords(data.missingKeywords || []);

    lastScore = {
      ...data,
      compositeScore: score,
      jobTitle: currentJobTitle,
      jobDescription: currentJobDesc,
      updatedAt: data.updatedAt || new Date().toISOString(),
    };
  };

  const persistProjectContext = async (jobTitle, jobDescription) => {
    if (!currentProjectId) return;

    const [jobKey] = getCachedKeys();
    await storageSet({
      [jobKey]: {
        jobTitle,
        jobDescription,
        updatedAt: new Date().toISOString(),
      }
    });
  };

  const persistScoreContext = async (data) => {
    if (!currentProjectId) return;

    const [, scoreKey] = getCachedKeys();
    await storageSet({
      [scoreKey]: {
        ...data,
        jobTitle: currentJobTitle,
        jobDescription: currentJobDesc,
        updatedAt: new Date().toISOString(),
      }
    });
  };

  const startScoringFlow = async () => {
    if (!currentProjectId) {
      showError('No project is active. Open an Overleaf project first.');
      return;
    }

    lastAction = startScoringFlow;
    els.loadingCopy.textContent = currentJobTitle
      ? `Analyzing ${currentJobTitle} against the current resume…`
      : 'Analyzing your resume against the saved job description…';
    showView('loading');

    try {
      const latexResponse = await sendMessage({
        action: 'GET_LATEX_TEXT',
        tabId: currentTabId,
      });

      if (!latexResponse?.ok) {
        throw new Error(latexResponse?.error || 'Failed to extract LaTeX text from Overleaf');
      }

      const scoreResponse = await sendMessage({
        action: 'SCORE_RESUME',
        projectId: currentProjectId,
        latexText: latexResponse.latexText,
      });

      if (!scoreResponse?.ok) {
        throw new Error(scoreResponse?.error || 'Scoring failed');
      }

      await persistProjectContext(currentJobTitle, currentJobDesc);
      await persistScoreContext(scoreResponse.data);
      renderResults(scoreResponse.data, { fromCache: false });
    } catch (error) {
      showError(error.message);
    }
  };

  const prefillForm = ({ jobTitle = '', jobDescription = '' } = {}) => {
    els.jobTitle.value = jobTitle;
    els.jobDescription.value = jobDescription;
    currentJobTitle = jobTitle;
    currentJobDesc = jobDescription;
  };

  const restoreCachedState = async () => {
    const state = await loadCachedProjectState();

    if (!state) {
      updateSavedTargetCard({ hasSaved: false });
      showView('empty');
      return;
    }

    prefillForm({ jobTitle: state.jobTitle, jobDescription: state.jobDescription });
    updateSavedTargetCard({
      hasSaved: Boolean(state.jobTitle || state.jobDescription),
      jobTitle: state.jobTitle,
      jobDescription: state.jobDescription,
    });

    if (state.score) {
      renderResults(state.score, { fromCache: true });
      return;
    }

    showView('empty');
  };

  const escapeHtml = (value) => {
    const div = document.createElement('div');
    div.textContent = String(value ?? '');
    return div.innerHTML;
  };

  const init = async () => {
    try {
      const storedTheme = await getThemePreference();
      applyTheme(storedTheme);

      const [tab] = await chrome.tabs.query({ active: true, currentWindow: true });
      if (!tab) {
        setSetupMode(false, 'No active tab found. Open an Overleaf project to start scoring.');
        showView('empty');
        return;
      }

      const url = tab.url || '';
      const overleafMatch = url.match(/overleaf\.com\/project\/([a-f0-9]+)/);

      if (!overleafMatch) {
        setSetupMode(false, 'Open an Overleaf project first to enable resume extraction and scoring.');
        showView('empty');
        return;
      }

      currentTabId = tab.id;
      currentProjectId = overleafMatch[1];
      setSetupMode(true, 'Ready to analyze the current Overleaf resume.');
      els.savedTargetProject.textContent = formatProjectPill(currentProjectId);
      els.projectPill.textContent = formatProjectPill(currentProjectId);

      await restoreCachedState();
    } catch (error) {
      showError(error.message);
    }
  };

  els.themeToggle.addEventListener('click', async () => {
    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
    applyTheme(nextTheme);
    await saveThemePreference(nextTheme);
  });

  els.jdForm.addEventListener('submit', async (event) => {
    event.preventDefault();

    const jobTitle = els.jobTitle.value.trim();
    const jobDescription = els.jobDescription.value.trim();

    if (!jobTitle || !jobDescription) {
      return;
    }

    currentJobTitle = jobTitle;
    currentJobDesc = jobDescription;

    lastAction = async () => {
      try {
        await persistProjectContext(jobTitle, jobDescription);

        const response = await sendMessage({
          action: 'SAVE_JOB_DESC',
          projectId: currentProjectId,
          jobTitle,
          jobDescription,
        });

        if (!response?.ok) {
          throw new Error(response?.error || 'Failed to save job description');
        }

        await startScoringFlow();
      } catch (error) {
        showError(error.message);
      }
    };

    await lastAction();
  });

  els.btnRescore.addEventListener('click', () => {
    startScoringFlow();
  });

  els.btnEditJd.addEventListener('click', () => {
    prefillForm({ jobTitle: currentJobTitle, jobDescription: currentJobDesc });
    updateSavedTargetCard({
      hasSaved: Boolean(currentJobTitle || currentJobDesc),
      jobTitle: currentJobTitle,
      jobDescription: currentJobDesc,
    });
    showView('empty');
  });

  els.btnTryAgain.addEventListener('click', () => {
    if (typeof lastAction === 'function') {
      lastAction();
      return;
    }

    showView('empty');
  });

  document.addEventListener('DOMContentLoaded', init);
})();